# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# HuggingFace caches (created on first run)
.hf_cache/
.cache/

# ---- Data ----
# Raw BEAD CSVs are CC-BY-NC; teammates download from HF directly.
data/bead/*.csv

# Frozen + v1 split JSONLs: regenerable from CSVs at the seed in
# splits_manifest.json. The hashes are checked in; the JSONLs are not.
data/frozen/*.jsonl
data/frozen/**/*.jsonl
data/processed/*.jsonl

# Raw downloads for the cross-eval datasets (BABE/cajcodes live in HF cache;
# WNC is a local git clone). Same convention as data/bead/.
data/wnc/
data/babe/
data/cajcodes/

# Any future BEAD subset directories generated by freeze_splits.py.
_smoke_frozen/
data/processed_mock/

# ---- Outputs ----
# Adapters and predictions are large or per-run; share via Drive, not GitHub.
outputs/**/adapter/
outputs/**/adapter_smoke/
outputs/**/predictions.jsonl
outputs/**/predictions_smoke.jsonl
outputs/**/checkpoint-*/
# TRL auto-generates an HF model-card README.md inside the run dir when
# intermediate checkpoints are saved. It describes adapter weights that we
# don't track anyway, so it has no place in the repo.
outputs/**/README.md

# ---- Baselines ----
# Per-baseline predictions (regeneratable from the committed notebook + frozen splits).
baselines/**/*predictions*.jsonl
outputs/_interactive_smoke/
outputs/_smoke_qlora/
outputs/_smoke_run/

# Sweep manifest is small and useful, but per-run logs aren't.
logs/*
!logs/.gitkeep

# fcntl advisory lock sibling for outputs/manifest.csv (transient, may linger
# on hard kill).
outputs/manifest.csv.lock

# ---- Cruft ----
*.zip
terminal output*.txt
tillicum-1k-calibration-2026-05-09/
# Third-party reference clone (its own git repo at UWrc/tillicum-onboarding-imt526a).
# Kept locally for reading; not part of this project's history.
tillicum-onboarding-imt526a/

# checkpoints/ is a placeholder dir from the calibration layout; keep the
# directory but ignore anything written into it. (`.gitkeep` will be tracked.)
checkpoints/*
!checkpoints/.gitkeep

# ---- Editor / IDE ----
.idea/
.vscode/
*.swp
*~

# ---- Env files (may carry HF_TOKEN etc.) ----
.env
.env.*
!.env.example
